// Link of the Problem: https://leetcode.com/problems/replace-elements-with-greatest-element-on-right-side/
// description: 
/* 

Given an array arr, replace every element in that array with the greatest element among the elements to its right, and replace the last element with -1.

After doing so, return the array.


*/
// Code With C++


class Solution {
public:
    vector<int> replaceElements(vector<int>& arr) {
        
       
       int lastValue=arr.at(arr.size()-1);
        arr.at(arr.size()-1)=-1;
        for (int i=arr.size()-2 ; i>=0 ; i--){
            int temp=arr.at(i);
            arr.at(i) = lastValue;
            if (lastValue<temp){
                 lastValue=temp;
            }
            
        }
       
        return arr;
    }
};
